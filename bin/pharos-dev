#!/usr/bin/env bash
#
# Development entrypoint for the MCP host (Claude Code, Cursor, etc.) to
# spawn `pharos` while iterating in this repo.
#
# Why a wrapper instead of `mix start`:
#   `mix run` prints compilation progress to STDOUT, which corrupts the
#   stdio JSON-RPC stream the MCP host expects. The host parses the first
#   line as JSON-RPC, fails on `Compiling 28 files (.gleam)`, and closes
#   the connection (MCP error -32000).
#
# What this script does:
#   1. Compiles the project, sending all output to STDERR (host ignores).
#   2. Boots Erlang directly (no Mix in the runtime path) so STDOUT stays
#      reserved for the MCP protocol.
#
# Replaced by the Burrito-built binary at Milestone 6; until then, MCP
# config points at this script.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ORIG_CWD="$(pwd)"
cd "$PROJECT_ROOT"

# Ensure asdf shims are reachable. Claude Code's spawned subprocess may
# inherit a minimal PATH that omits ~/.asdf/shims; prepend it defensively.
if [ -d "$HOME/.asdf/shims" ]; then
  export PATH="$HOME/.asdf/shims:$PATH"
fi

# Compile if needed. All output goes to stderr — the host only watches
# stdout. Mix is the canonical build path now (the hpack_erl naming
# workaround in mix.exs handles the prior pain point); `_build/dev/lib`
# carries every BEAM the runtime needs, including the OTP application
# trampoline `pharos:main/0`.
mix compile 1>&2

# Restore the original cwd before exec'ing erl so pharos's project-TOML
# walk-up (and any other cwd-sensitive code) sees the directory the
# invoker was actually in. Important for `.pharos.toml` discovery from
# arbitrary project trees.
cd "$ORIG_CWD"

# Boot Erlang directly. -noshell keeps the line discipline simple;
# `pharos:main/0` is our stdin loop and returns when EOF closes stdin.
# halt(0) exits the BEAM cleanly afterward.
#
# -noinput is load-bearing under MCP-host stdio: without it, Erlang's
# `prim_tty` driver claims fd 0 and emits a `driver_select stealing
# control of fd=0` error to fd 1 once pharos opens its own
# `{fd, 0, 0}` port for synchronous per-line stdin (M11 fix; mirrors
# rel/vm.args.eex for the burrito release). The stray error line
# corrupts the MCP NDJSON stream and the host hangs up.
#
# Code paths use absolute paths anchored at PROJECT_ROOT so they
# resolve correctly regardless of where erl was invoked from. Forwarded
# argv (`-extra "$@"`) lands in `init:get_plain_arguments/0` so meta
# flags like `--doctor`, `--purge-cache`, and `--print-language-config`
# work via this wrapper.
#
# `-extra` (not `--`) is required under `-noinput`. The `--` alias for
# `-extra` does NOT propagate plain arguments when `-noinput` is in
# effect — empirically confirmed; meta flags silently fell through to
# the normal boot path otherwise. The M11 stdio fix added `-noinput`
# for the burrito-release prim_tty issue and quietly broke meta-flag
# forwarding here at the same time.
exec erl \
  -pa $PROJECT_ROOT/_build/dev/lib/*/ebin \
  -noshell \
  -noinput \
  -eval "pharos:main(), halt(0)." \
  -extra "$@"
