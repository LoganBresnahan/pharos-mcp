{
  "name": "pharos-mcp",
  "version": "0.0.1",
  "description": "MCP server bridging LLMs to Language Server Protocol (LSP) servers. Brings hover, goto_definition, find_references, and 36 more LSP tools to Claude and other MCP-aware agents. Single-binary, 23 languages.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lsp",
    "language-server-protocol",
    "claude",
    "anthropic",
    "ai-tools",
    "code-intelligence",
    "lsp-bridge",
    "mcp-server",
    "rust-analyzer",
    "gopls",
    "tsserver",
    "pyright",
    "metals",
    "haskell-language-server",
    "developer-tools",
    "burrito",
    "gleam",
    "erlang",
    "beam"
  ],
  "license": "MIT",
  "homepage": "https://github.com/LoganBresnahan/pharos-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LoganBresnahan/pharos-mcp.git"
  },
  "bin": {
    "pharos": "bin/pharos.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "vendor/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": ["linux", "darwin", "win32"],
  "cpu": ["x64", "arm64"]
}
