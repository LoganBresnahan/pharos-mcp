# Mix / Elixir
/_build/
/cover/
/deps/
/doc/_build/
*.ez
erl_crash.dump

# Gleam
/build/
*.beam

# Burrito output
/burrito_out/

# IDE / editor
.elixir_ls/
.elixir-tools/
.lexical/
.idea/
*.swp
*.swo

# VSCode — track project-level settings/extensions, ignore everything else
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db

# Python (bin/test-*.py helpers)
__pycache__/
*.pyc

# npm package's bundled binaries — populated at release time by
# copying from /burrito_out/. The scaffolding under /npm/
# (package.json, bin/, scripts/, README.md) IS committed.
/npm/vendor/
/npm/node_modules/

# Local secrets / config overrides
*.local.exs
.envrc
.env

# Dogfood fixtures (bin/dogfood-fixtures.sh clones public repos here)
/tmp/

# Notes
/notes/
.claude/

.private/
bench/data/
bench/results/

# jdtls-generated workspace state — Eclipse JDT.LS auto-creates these
# inside any Java project root it imports. Not source; rebuilt every
# run. Applies to all Java fixtures under bench/fixtures/.
bench/fixtures/**/.classpath
bench/fixtures/**/.project
bench/fixtures/**/.settings/
bench/fixtures/**/target/
