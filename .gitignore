# Mix / Elixir
/_build/
/cover/
/deps/
/doc/_build/
*.ez
erl_crash.dump

# Gleam
/build/
*.beam

# Burrito output
/burrito_out/

# IDE / editor
.elixir_ls/
.elixir-tools/
.lexical/
.idea/
*.swp
*.swo

# VSCode — track project-level settings/extensions, ignore everything else
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db

# Python (bin/test-*.py helpers)
__pycache__/
*.pyc

# npm package's bundled binaries — populated at release time by
# copying from /burrito_out/. The scaffolding under /npm/
# (package.json, bin/, scripts/, README.md) IS committed.
/npm/vendor/
/npm/node_modules/

# Local secrets / config overrides
*.local.exs
.envrc
.env

# Dogfood fixtures (bin/dogfood-fixtures.sh clones public repos here)
/tmp/

# Notes
/notes/
.claude/

.private/
bench/data/
bench/results/

# LSP-generated workspace state — every language server caches
# analysis/index state inside the project root. Not source; rebuilt
# every run. Covers jdtls (Java), clojure-lsp + clj-kondo (Clojure),
# metals + bloop (Scala), and scala-cli's deps cache.
bench/fixtures/**/.classpath
bench/fixtures/**/.project
bench/fixtures/**/.settings/
bench/fixtures/**/target/
bench/fixtures/**/.lsp/
bench/fixtures/**/.clj-kondo/
bench/fixtures/**/.cpcache/
bench/fixtures/**/.metals/
bench/fixtures/**/.bloop/
bench/fixtures/**/.scala-build/
bench/fixtures/**/project/target/
bench/fixtures/**/project/project/
